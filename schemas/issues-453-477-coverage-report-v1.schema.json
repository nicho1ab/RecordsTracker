        "execution_mode": { "enum": ["dry_run", "apply"] },
        "started_at": { "$ref": "#/$defs/nullableTimestamp" },
        "completed_at": { "$ref": "#/$defs/nullableTimestamp" },
        "last_successful_refresh_at": { "$ref": "#/$defs/nullableTimestamp" },
        "pipeline_version": { "$ref": "#/$defs/safeId" },
        "checkpoint_state": {
          "enum": ["not_started", "available", "complete", "interrupted", "failed", "unavailable"]
        },
        "checkpoint_identity": {
          "oneOf": [
            { "$ref": "#/$defs/safeId" },
            { "type": "null" }
          ]
        },
        "selected_count": { "$ref": "#/$defs/count" },
        "processed_count": { "$ref": "#/$defs/count" },
        "changed_count": { "$ref": "#/$defs/count" },
        "unchanged_count": { "$ref": "#/$defs/count" },
        "skipped_count": { "$ref": "#/$defs/count" },
        "warning_count": { "$ref": "#/$defs/count" },
        "failed_count": { "$ref": "#/$defs/count" },
        "operational_failure_category": {
          "enum": [
            "none",
            "retrieval_failed",
            "import_failed",
            "validation_failed",
            "missing_artifact",
            "hash_validation_failed",
            "unsupported_layout",
            "conflicting_sources",
            "checkpoint_interrupted",
            "contract_unavailable",
            "contract_version_mismatch",
            "controlled_unknown_failure"
          ]
