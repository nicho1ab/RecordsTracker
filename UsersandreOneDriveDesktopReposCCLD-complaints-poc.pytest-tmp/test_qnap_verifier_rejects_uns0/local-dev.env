CCLD_POSTGRES_DB=ccld_records
CCLD_POSTGRES_USER=ccld_app
CCLD_POSTGRES_PASSWORD=replace-with-strong-local-password
CCLD_HOSTED_PORT=8000
CCLD_HOSTED_PAGE_DATA_MODE=postgres
CCLD_HOSTED_TESTER_AUTH_MODE=local-dev
CCLD_HOSTED_TESTER_AUTH_PROVIDER_CLASS=cloudflare-access
CCLD_CLOUDFLARE_ACCESS_TEAM_DOMAIN=<cloudflare-team-domain-placeholder>
CCLD_CLOUDFLARE_ACCESS_AUD=<cloudflare-access-aud-placeholder>
CCLD_CLOUDFLARE_ACCESS_ALLOWED_EMAIL_DOMAINS=<allowed-email-domain-placeholder>
CCLD_CLOUDFLARE_ACCESS_ALLOWED_EMAILS=<allowed-email-placeholder>
CCLD_CLOUDFLARE_ACCESS_JWKS_CACHE_SECONDS=300
CCLD_HOSTED_TESTER_OIDC_ISSUER=<provider-issuer-placeholder>
CCLD_HOSTED_TESTER_OIDC_CLIENT_ID=<provider-client-id-placeholder>
CCLD_HOSTED_TESTER_OIDC_CALLBACK_PATH=/auth/callback
CCLD_HOSTED_TESTER_OIDC_SCOPES=openid profile
CCLD_HOSTED_TESTER_LOCAL_DEV_AUTH=enabled
GITHUB_FEEDBACK_REPO=
GITHUB_FEEDBACK_TOKEN=
GITHUB_FEEDBACK_DEFAULT_LABELS=
CCLD_RETRIEVAL_ENABLED=disabled
CCLD_RETRIEVAL_RAW_DIR=/app/data/raw/ccld/retrieval
CCLD_RETRIEVAL_MAX_DATE_RANGE_DAYS=366
CCLD_RETRIEVAL_PER_JOB_LIMIT=5
CCLD_RETRIEVAL_RATE_LIMIT_PER_ACTOR=3
CCLD_RETRIEVAL_TIMEOUT_SECONDS=30
CCLD_RETRIEVAL_RETRY_LIMIT=1
CCLD_RETRIEVAL_DEMO_MODE=
CCLD_FACILITY_REFERENCE_CSV=
