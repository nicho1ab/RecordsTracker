# Copy this file to .env on the deployment host and replace placeholder values.
# Keep .env untracked. Do not commit real database passwords or hosted settings.
# Keep this shape portable across QNAP Docker and later cloud hosts: app runtime,
# PostgreSQL, raw/processed volumes, auth settings, and backups are separate concerns.

CCLD_POSTGRES_DB=ccld_records
CCLD_POSTGRES_USER=ccld_app
CCLD_POSTGRES_PASSWORD=replace-with-strong-local-password
CCLD_HOSTED_PORT=8000
CCLD_HOSTED_PAGE_DATA_MODE=postgres

# Hosted tester auth runtime. Keep provider-specific values in the untracked .env file.
CCLD_HOSTED_TESTER_AUTH_MODE=production
CCLD_HOSTED_TESTER_AUTH_PROVIDER_CLASS=managed-oidc-oauth2
CCLD_HOSTED_TESTER_OIDC_ISSUER=<provider-issuer-placeholder>
CCLD_HOSTED_TESTER_OIDC_CLIENT_ID=<provider-client-id-placeholder>
CCLD_HOSTED_TESTER_OIDC_CALLBACK_PATH=/auth/callback
CCLD_HOSTED_TESTER_OIDC_SCOPES=openid profile
CCLD_HOSTED_TESTER_LOCAL_DEV_AUTH=disabled

# Optional server-side GitHub Issues feedback intake. Keep token server-side only.
GITHUB_FEEDBACK_REPO=<your-github-org-or-user>/<repository-name>
GITHUB_FEEDBACK_TOKEN=<server-side-github-feedback-token>
GITHUB_FEEDBACK_DEFAULT_LABELS=

# Optional controlled server-side CCLD retrieval jobs. Keep disabled until the
# host has PostgreSQL, auth boundary, and raw artifact storage configured.
CCLD_RETRIEVAL_ENABLED=disabled
CCLD_RETRIEVAL_RAW_DIR=/app/data/raw/ccld/retrieval
CCLD_RETRIEVAL_MAX_DATE_RANGE_DAYS=366
CCLD_RETRIEVAL_PER_JOB_LIMIT=5
CCLD_RETRIEVAL_RATE_LIMIT_PER_ACTOR=3
CCLD_RETRIEVAL_TIMEOUT_SECONDS=30
CCLD_RETRIEVAL_RETRY_LIMIT=1

# Optional local/test CCLD facility reference CSV path inside the app container.
# For Docker, mount the file under /app/data/raw and point this value at it.
# Cloud hosts should map raw/processed/log storage to persistent volumes or a
# later approved object-storage adapter without hard-coding provider paths in app code.
CCLD_FACILITY_REFERENCE_CSV=
