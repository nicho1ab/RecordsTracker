# QNAP pilot environment template.
# Copy this file to .env on the deployment host, then replace or intentionally
# blank the placeholders below. Keep .env untracked. Do not commit real database
# passwords, GitHub tokens, provider settings, hosted URLs, or account-specific
# values. QNAP is the first pilot runtime, not a permanent platform lock-in.

# Required: PostgreSQL container and app port.
CCLD_POSTGRES_DB=ccld_records
CCLD_POSTGRES_USER=ccld_app
CCLD_POSTGRES_PASSWORD=replace-with-strong-local-password
CCLD_HOSTED_PORT=8000

# Required for QNAP pilot: PostgreSQL-backed hosted pages.
# Use fixture-demo only for explicit local workstation demos/tests.
CCLD_HOSTED_PAGE_DATA_MODE=postgres

# Required for QNAP pilot: production auth readiness defaults and Cloudflare Access JWT bridge.
# Cloudflare Access protects the public hostname, then RecordsTracker validates
# the Access JWT header before creating a minimal feedback actor. Keep all real
# team domains, AUD tags, and allowlists host-local.
CCLD_HOSTED_TESTER_AUTH_MODE=production
CCLD_HOSTED_TESTER_AUTH_PROVIDER_CLASS=cloudflare-access
CCLD_CLOUDFLARE_ACCESS_TEAM_DOMAIN=<cloudflare-team-domain-placeholder>
CCLD_CLOUDFLARE_ACCESS_AUD=<cloudflare-access-aud-placeholder>
CCLD_CLOUDFLARE_ACCESS_ALLOWED_EMAIL_DOMAINS=<allowed-email-domain-placeholder>
CCLD_CLOUDFLARE_ACCESS_ALLOWED_EMAILS=<allowed-email-placeholder>
CCLD_CLOUDFLARE_ACCESS_JWKS_CACHE_SECONDS=300

# Optional future OIDC placeholders. Not required for the Cloudflare Access
# feedback bridge, and must not include client secrets.
CCLD_HOSTED_TESTER_OIDC_ISSUER=<provider-issuer-placeholder>
CCLD_HOSTED_TESTER_OIDC_CLIENT_ID=<provider-client-id-placeholder>
CCLD_HOSTED_TESTER_OIDC_CALLBACK_PATH=/auth/callback
CCLD_HOSTED_TESTER_OIDC_SCOPES=openid profile
CCLD_HOSTED_TESTER_LOCAL_DEV_AUTH=disabled

# Optional server-side GitHub Issues feedback intake.
# To intentionally disable GitHub feedback, leave BOTH GITHUB_FEEDBACK_REPO and
# GITHUB_FEEDBACK_TOKEN blank. To enable it, set BOTH values on the host.
# Keep the token server-side only; never commit it.
GITHUB_FEEDBACK_REPO=
GITHUB_FEEDBACK_TOKEN=
GITHUB_FEEDBACK_DEFAULT_LABELS=

# Optional controlled server-side CCLD retrieval jobs.
# To intentionally disable live retrieval, keep CCLD_RETRIEVAL_ENABLED=disabled.
# To enable production-like retrieval, set enabled only after PostgreSQL,
# auth/access controls, persistent raw artifact storage, and conservative limits
# are ready. Supported retrieval remains complaint records only for now;
# all_supported still resolves to complaints.
CCLD_RETRIEVAL_ENABLED=disabled
CCLD_RETRIEVAL_RAW_DIR=/app/data/raw/ccld/retrieval
CCLD_RETRIEVAL_MAX_DATE_RANGE_DAYS=366
CCLD_RETRIEVAL_PER_JOB_LIMIT=5
CCLD_RETRIEVAL_RATE_LIMIT_PER_ACTOR=3
CCLD_RETRIEVAL_TIMEOUT_SECONDS=30
CCLD_RETRIEVAL_RETRY_LIMIT=1

# Local-dev scaffold validation only. Must remain blank for QNAP pilot mode.
# Set to mock-success only with local-dev auth and fixture-demo page data on a
# developer workstation; it uses committed fixtures and makes no live CCLD calls.
CCLD_RETRIEVAL_DEMO_MODE=

# Optional local/test CCLD facility reference CSV path inside the app container.
# For Docker, mount the file under /app/data/raw and point this value at it.
# Cloud hosts should map raw/processed/log storage to persistent volumes or a
# later approved object-storage adapter without hard-coding provider paths in app code.
CCLD_FACILITY_REFERENCE_CSV=
